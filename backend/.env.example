# Configuración del backend EcoClasificador
# Copiá este archivo a `.env` para correr localmente y ajustá lo que necesites.

# Puerto del servidor (Railway / Render lo inyectan automáticamente)
PORT=8000

# Nivel de logs (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# CORS — orígenes permitidos.
# "*" para wildcard, o lista separada por coma:
# CORS_ALLOW_ORIGINS=https://clasificadorresiduo.lat,https://kalu-20.github.io
CORS_ALLOW_ORIGINS=*

# CORS opcional por regex (Vercel preview deploys, etc.):
# CORS_ALLOW_ORIGIN_REGEX=https://.*\.vercel\.app
